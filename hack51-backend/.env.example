# ============================
# Hack51 Backend - Environment
# ============================

# App
PORT=3000
NODE_ENV=development

# JWT Secrets (use strong random strings in production)
JWT_ACCESS_SECRET=replace-with-a-strong-access-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Supabase (Database)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Direct PostgreSQL connection (for migrations via Supabase connection string)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Resend (Email / SMTP)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Hack51

# OTP Settings
OTP_EXPIRES_MINUTES=10

# Frontend URL (for any redirect links)
FRONTEND_URL=http://localhost:5173

# Bcrypt Rounds
BCRYPT_ROUNDS=12

# ============================================================================
# Pricing (NGN). Override these to change pricing without touching code.
# Defaults are shown — leave commented to use defaults.
# ============================================================================
# ADMIN_FEE_NGN=800000
# UNIT_PRICE_NGN=180000
# FULL_LIST_UNLOCK_NGN=240000

# ============================================================================
# Feature Flags
# ============================================================================
# SKIP_PAYMENT — when true, /publish and /unlock skip Paystack and mark the
# payment as success immediately. Default: ON in non-production. Force OFF by
# setting SKIP_PAYMENT=false. ALWAYS off in production.
# SKIP_PAYMENT=true

# DEV_MODE — when true, OTP codes are returned in registration / resend /
# forgot-password responses (so the frontend dev can test without email).
# Also enables the GET /admin/dev/otp-info/:email endpoint.
# Default: ON in non-production. ALWAYS off in production.
# DEV_MODE=true

# ============================================================================
# Paystack (not yet active — fill in when you're ready)
# ============================================================================
# PAYSTACK_SECRET_KEY=sk_test_xxx
# PAYSTACK_WEBHOOK_SECRET=your-webhook-secret
