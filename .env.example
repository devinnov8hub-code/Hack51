# ============================
# Hack51 Backend - Environment
# ============================

# App
PORT=3000
NODE_ENV=development

# JWT Secrets (use strong random strings in production)
JWT_ACCESS_SECRET=replace-with-a-strong-access-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Supabase (Database)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Direct PostgreSQL connection (for migrations via Supabase connection string)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Resend (Email / SMTP)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Hack51

# OTP Settings
OTP_EXPIRES_MINUTES=10

# Frontend URL (for any redirect links)
FRONTEND_URL=http://localhost:5173

# Bcrypt Rounds
BCRYPT_ROUNDS=12
